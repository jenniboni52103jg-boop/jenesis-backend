{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
     "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0"
    
  },
  "include": ["src"]
}

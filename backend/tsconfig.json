{
  "compilerOptions": {
    "target": "ES2021",
    "module": "nodenext",
    //"module": "esnext",
   // "moduleResolution": "bundler",
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src"
  ],
  "extends": "expo/tsconfig.base"
}
